{
  "publisher": "pavithra-dev",
  "name": "faahh-sound",
  "license": "MIT",
  "displayName": "FaahhSound",
  "description": "Plays fahh sound on errors",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "faahhSound.testSound",
        "title": "Faahh Sound: Test Sound 🔊"
      },
      {
        "command": "faahhSound.toggle",
        "title": "Faahh Sound: Toggle On/Off"
      }
    ],
    "configuration": {
      "title": "FaahhSound",
      "properties": {
        "faahhSound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the faahh sound"
        },
        "faahhSound.minSeverity": {
          "type": "string",
          "default": "error",
          "enum": ["error", "warning"],
          "enumDescriptions": [
            "Only play sound on errors",
            "Play sound on both errors and warnings"
          ],
          "description": "Minimum severity level to trigger the sound"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "play-sound": "^1.1.6"
  }
}