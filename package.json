{
  "publisher": "pavithra-dev",
  "name": "dhagoolka-sound",
  "license": "MIT",
  "displayName": "Dhagoolka Sound",
  "description": "Plays sound on editor errors",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/ENG-MNOR/dhagoolka-sound.git"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dhagoolkaSound.testSound",
        "title": "Dhagoolka Sound: Test Sound 🔊"
      },
      {
        "command": "dhagoolkaSound.toggle",
        "title": "Dhagoolka Sound: Toggle On/Off"
      }
    ],
    "configuration": {
      "title": "Dhagoolka Sound",
      "properties": {
        "dhagoolkaSound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the sound"
        },
        "dhagoolkaSound.minSeverity": {
          "type": "string",
          "default": "error",
          "enum": ["error", "warning"],
          "enumDescriptions": [
            "Only play sound on errors",
            "Play sound on both errors and warnings"
          ],
          "description": "Minimum severity level to trigger the sound"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsix": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}
